{
  "enabled": true,

  "notify": {
    "terminal": true,
    "_note": "Print styled banner directly in the Claude Code terminal output"
  },

  "toast": {
    "enabled": true,
    "show_tool_events": false,
    "_note": "Windows toast popups. show_tool_events: toast on every Write/Edit/Bash"
  },

  "voice": {
    "enabled": false,
    "active_profile": "jarvis",
    "_note": "Disabled by default. Toggle with: .\\herald.ps1 --toggle voice"
  },

  "profiles": {
    "jarvis": {
      "name": "Microsoft David Desktop",
      "rate": -4,
      "volume": 95,
      "description": "Slow, deliberate, authoritative"
    },
    "default": {
      "name": "Microsoft David Desktop",
      "rate": -2,
      "volume": 90,
      "description": "Measured, professional cadence"
    },
    "zira": {
      "name": "Microsoft Zira Desktop",
      "rate": -1,
      "volume": 85,
      "description": "Female voice, neutral pace"
    }
  },

  "mobile": {
    "enabled": false,
    "ntfy_server": "https://ntfy.sh",
    "ntfy_topic": "",
    "ntfy_token": "",
    "push_on_complete": false,
    "_note": "Phone push via ntfy.sh. Set ntfy_topic then run --toggle mobile"
  },

  "hooks": {
    "on_stop": true,
    "on_tool_use": true
  },

  "announcements": {
    "tool_details": true
  }
}